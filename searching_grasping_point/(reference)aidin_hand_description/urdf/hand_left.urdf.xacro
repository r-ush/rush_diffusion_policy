<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="left_hand" 
              params="parent:='world' prefix:='left_' *origin "> <!-- xyz:='0 0 0' rpy:='0 0 0'" -->

    <!-- Joint connecting to parent -->
    <joint name="${prefix}hand_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}hand_base_link"/>
      <xacro:insert_block name="origin"/>
    </joint>
    
    <link name="${prefix}hand_base_link">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="package://aidin_hand_description/meshes/visual/body_left.STL" />
          </geometry>
          <material name="">
            <color rgba="0.22353 0.22353 0.22353 1" />
          </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://aidin_hand_description/meshes/collision/body_left_collision.STL" />
        </geometry>
      </collision>
      <inertial>
        <origin
          xyz="-0.00078195 0.0062725 0.091912"
          rpy="0 0 0" />
        <mass
          value="0.96362" />
        <inertia
          ixx="0.00040749"
          ixy="-1.8229E-05"
          ixz="-9.0692E-06"
          iyy="0.00061402"
          iyz="1.8795E-05"
          izz="0.00060699" />
      </inertial>
    </link>

